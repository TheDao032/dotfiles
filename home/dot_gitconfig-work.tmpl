# Work git identity — loaded automatically by ~/.gitconfig's includeIf
# block when the active repo is under ~/Documents/Bosch/.
# Source: home/.chezmoidata.toml → [work].
[user]
    name  = {{ .work.name }}
    email = {{ .work.email }}
{{- if .work.signingkey }}
    signingkey = {{ .work.signingkey }}

[commit]
    gpgsign = true

[tag]
    gpgsign = true

[gpg]
    program = gpg
{{- end }}
