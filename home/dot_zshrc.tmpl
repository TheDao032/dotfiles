#!/usr/bin/env zsh
# ~/.zshrc — rendered by chezmoi from home/dot_zshrc.tmpl
#
# DO NOT EDIT THIS FILE DIRECTLY. Edit the source template:
#   chezmoi edit ~/.zshrc
# Then apply:
#   chezmoi apply
#
# Secrets are NOT in this file. They're decrypted from
#   ~/.envrc.private  (rendered from home/encrypted_private_dot_envrc.private)
# Edit secrets with:  chezmoi edit ~/.envrc.private

# ─── oh-my-zsh ──────────────────────────────────────────────────────────────
export ZSH="$HOME/.oh-my-zsh"
ZSH_THEME="{{ .tools.omz_theme }}"
plugins=({{ range .tools.omz_plugins }}{{ . }} {{ end }})

# zsh-autosuggestions tuning — must be set BEFORE oh-my-zsh.sh sources the plugin.
# Strategy: prefer history, fall back to completion suggestions.
ZSH_AUTOSUGGEST_STRATEGY=(history completion)
# Suggestion text color (256-color code 8 = dark grey). Bump higher for more contrast.
ZSH_AUTOSUGGEST_HIGHLIGHT_STYLE='fg=8'

[ -d "$ZSH" ] && source "$ZSH/oh-my-zsh.sh"

# ─── editor preferences ─────────────────────────────────────────────────────
if [[ -n $SSH_CONNECTION ]]; then
    export EDITOR='vim'
else
    export EDITOR='{{ .tools.editor }}'
fi
export KUBE_EDITOR='{{ .tools.editor }}'

# ─── Homebrew shellenv (already loaded via .zprofile, this is belt-and-braces) ─
{{- if eq .chezmoi.os "darwin" }}
{{-   if eq .chezmoi.arch "arm64" }}
[ -x "{{ .paths.homebrew_prefix_arm }}/bin/brew" ] && eval "$({{ .paths.homebrew_prefix_arm }}/bin/brew shellenv)"
{{-   else }}
[ -x "{{ .paths.homebrew_prefix_intel }}/bin/brew" ] && eval "$({{ .paths.homebrew_prefix_intel }}/bin/brew shellenv)"
{{-   end }}
{{- end }}

# ─── zsh completion + plugins ───────────────────────────────────────────────
if type brew &>/dev/null; then
    FPATH="$(brew --prefix)/share/zsh-completions:$FPATH"
    autoload -Uz compinit && compinit
    compaudit | xargs chmod g-w 2>/dev/null || true
fi

# NOTE: zsh-autosuggestions / zsh-syntax-highlighting / zsh-completions are now
# loaded via the oh-my-zsh `plugins=()` array above. The plugin repos are cloned
# into $ZSH_CUSTOM/plugins/ by .chezmoiscripts/run_onchange_after_install-omz-plugins.sh.tmpl

# ─── language runtimes ──────────────────────────────────────────────────────
# Java — jenv manages multiple JDKs
command -v jenv >/dev/null && eval "$(jenv init -)"
export OPENJDKPATH="{{ if eq .chezmoi.arch "arm64" }}{{ .paths.homebrew_prefix_arm }}{{ else }}{{ .paths.homebrew_prefix_intel }}{{ end }}/opt/openjdk"

# Ruby — rbenv
command -v rbenv >/dev/null && eval "$(rbenv init -)"

# Node — nvm (via homebrew)
{{- if eq .chezmoi.arch "arm64" }}
export NVM_DIR="$HOME/.nvm"
[ -s "{{ .paths.homebrew_prefix_arm }}/opt/nvm/nvm.sh" ] && \. "{{ .paths.homebrew_prefix_arm }}/opt/nvm/nvm.sh"
[ -s "{{ .paths.homebrew_prefix_arm }}/opt/nvm/etc/bash_completion.d/nvm" ] && \. "{{ .paths.homebrew_prefix_arm }}/opt/nvm/etc/bash_completion.d/nvm"
{{- end }}

# Lua — luaver
[ -s "$HOME/.luaver/luaver" ] && \. "$HOME/.luaver/luaver"
[ -s "$HOME/.luaver/completions/luaver.bash" ] && \. "$HOME/.luaver/completions/luaver.bash"

# Go
export GOPRIVATE='github.com/{{ .user.github }}/*,github.com/TMMFZ/*'

# Perl
export PERLPATH="$HOME/perl5"
export PERL5LIB="$HOME/perl5/lib/perl5${PERL5LIB:+:${PERL5LIB}}"
export PERL_LOCAL_LIB_ROOT="$HOME/perl5${PERL_LOCAL_LIB_ROOT:+:${PERL_LOCAL_LIB_ROOT}}"
export PERL_MB_OPT="--install_base \"$HOME/perl5\""
export PERL_MM_OPT="INSTALL_BASE=$HOME/perl5"

# ─── tooling paths ──────────────────────────────────────────────────────────
# Postgres
export POSTGRESQL_PATH="/usr/local/opt/postgresql@16"  # intel-style; harmless on arm if missing

# Neovim mason
MASON_PATH="$HOME/.local/share/nvim/mason"

# Kubernetes
export KUBECONFIG="$HOME/.kube/config"

# Android SDK
export ANDROID_SDK_ROOT="$HOME/Library/Android/sdk"
export ANDROID_HOME="$ANDROID_SDK_ROOT"

# Colima
{{- if eq .chezmoi.arch "arm64" }}
COLIMA_BIN="{{ .paths.homebrew_prefix_arm }}/opt/colima/bin"
{{- else }}
COLIMA_BIN="{{ .paths.homebrew_prefix_intel }}/opt/colima/bin"
{{- end }}

# Puppeteer
export PUPPETEER_CACHE_DIR="$HOME/.cache/puppeteer"
export PUPPETEER_EXECUTABLE_PATH="$HOME/.cache/puppeteer/chrome-headless-shell/mac_arm-144.0.7559.96/chrome-headless-shell-mac-arm64/chrome-headless-shell"

# ─── compilation flags (openssl/readline/libyaml + openjdk include) ─────────
{{- if eq .chezmoi.os "darwin" }}
{{-   $brew := .paths.homebrew_prefix_arm }}
{{-   if ne .chezmoi.arch "arm64" }}{{- $brew = .paths.homebrew_prefix_intel }}{{- end }}
export LDFLAGS="-L{{ $brew }}/opt/openssl@3/lib -L{{ $brew }}/opt/readline/lib -L{{ $brew }}/opt/libyaml/lib"
export CPPFLAGS="-I{{ $brew }}/opt/openssl@3/include -I{{ $brew }}/opt/readline/include -I{{ $brew }}/opt/libyaml/include -I$OPENJDKPATH/include"
export CPATH="{{ $brew }}/include"
export LIBRARY_PATH="{{ $brew }}/lib"
export PKG_CONFIG_PATH="{{ $brew }}/opt/openssl@3/lib/pkgconfig:{{ $brew }}/opt/readline/lib/pkgconfig:{{ $brew }}/opt/libyaml/lib/pkgconfig:{{ $brew }}/lib/pkgconfig"
{{- end }}

# ─── PATH (last; everything above can prepend) ──────────────────────────────
{{- if eq .chezmoi.os "darwin" }}
{{-   $brew := .paths.homebrew_prefix_arm }}
{{-   if ne .chezmoi.arch "arm64" }}{{- $brew = .paths.homebrew_prefix_intel }}{{- end }}
export PATH="\
$HOME/.jenv/shims:\
$HOME/.local/share/nvim/mason/bin:\
${COLIMA_BIN}:\
$HOME/.rvm/bin:\
$HOME/.pub-cache/bin:\
$HOME/.jenv/bin:\
$HOME/.rbenv/bin:\
$(go env GOPATH 2>/dev/null)/bin:\
$HOME/.asdf/shims:\
$(brew --prefix rustup 2>/dev/null)/bin:\
{{ $brew }}/bin:\
/usr/local/sbin:/usr/local/bin:\
$HOME/.local/bin:\
$OPENJDKPATH/bin:\
$PERLPATH/bin:\
$POSTGRESQL_PATH/bin:\
$MASON_PATH/bin:\
$HOME/.venv/bin:\
/opt/puppetlabs/bin:\
${ASDF_DATA_DIR:-$HOME/.asdf}/shims:\
$HOME/Documents/puppetlabs/puppet-editor-services:\
$ANDROID_SDK_ROOT/platform-tools:\
$ANDROID_SDK_ROOT/emulator:\
$ANDROID_SDK_ROOT/cmdline-tools/latest/bin:\
$PATH"
{{- end }}

# ─── prompt ─────────────────────────────────────────────────────────────────
export RPROMPT='[%{$fg_bold[blue]%} %D{%y/%m/%f} |%@ %{$reset_color%}]'

# ─── interactive niceties ───────────────────────────────────────────────────
# fzf — `fzf --zsh` was added in fzf 0.48 (Dec 2023). Ubuntu apt ships 0.44 and
# still uses the legacy sourced-scripts approach. Try modern first, fall back.
if command -v fzf >/dev/null; then
    if fzf --zsh >/dev/null 2>&1; then
        source <(fzf --zsh)
    elif [[ -f /usr/share/doc/fzf/examples/key-bindings.zsh ]]; then
        source /usr/share/doc/fzf/examples/key-bindings.zsh
        [[ -f /usr/share/doc/fzf/examples/completion.zsh ]] && source /usr/share/doc/fzf/examples/completion.zsh
    fi
fi

# OpenClaw (defensive — only if installed)
if command -v openclaw &>/dev/null; then
    export NODE_OPTIONS='--no-deprecation'
    source <(openclaw completion --shell zsh)
fi

# ngrok
if command -v ngrok &>/dev/null; then
    eval "$(ngrok completion)"
fi

# ─── aliases ────────────────────────────────────────────────────────────────
alias pyactive='source ~/.venv/bin/activate'
command -v bat >/dev/null && alias cat='bat --paging=never'

# ─── vagrant ────────────────────────────────────────────────────────────────
export VAGRANT_DISABLE_STRICT_DEPENDENCY_ENFORCEMENT=1

# ─── per-machine (non-secret) ───────────────────────────────────────────────
export OZMO_REPO_DIR="$HOME/Documents/freelancer/meteorsops/ozmo/ozmo"
export DOCKER_VOL_HOME_DEVICE="$OZMO_REPO_DIR/ozmo_home_dir"

# ─── SECRETS — sourced from age-encrypted file ──────────────────────────────
# All sensitive env vars (HCP_CLIENT_*, GITLAB_TOKEN, GITHUB_TOKEN, TIKTOK_*,
# VAGRANT_CLOUD_ORG, etc.) live in ~/.envrc.private which is rendered by
# chezmoi from an age-encrypted source. To edit:
#   chezmoi edit ~/.envrc.private
# (chezmoi decrypts on edit, re-encrypts on save.)
# Use if/then/fi (not `[ -f X ] && source X`) so the missing-file case returns
# 0 instead of leaking exit 1 to the prompt — robbyrussell shows a red arrow
# when $? != 0, which makes the prompt look "errored" just from a missing
# optional file.
if [ -f "$HOME/.envrc.private" ]; then
    source "$HOME/.envrc.private"
fi

# ─── machine-local overrides (NOT in git) ───────────────────────────────────
# Anything ~/.zshrc.local will be sourced last. Use for one-off machine tweaks
# you don't want to template (e.g., experimental aliases). NEVER put secrets here.
if [ -f "$HOME/.zshrc.local" ]; then
    source "$HOME/.zshrc.local"
fi

# Belt-and-braces: ensure rc-load exit code is 0 so the prompt indicator
# reflects YOUR commands, not "the last conditional in zshrc failed".
true
