#!/usr/bin/env bash
# run_once_after_install-oh-my-zsh.sh — bootstrap oh-my-zsh on first apply.
# This is run_once so it only fires when this exact script content hasn't run
# on this machine before.

set -euo pipefail

# Already installed? No-op.
if [ -d "$HOME/.oh-my-zsh" ]; then
    echo "==> oh-my-zsh already installed at ~/.oh-my-zsh"
    exit 0
fi

# oh-my-zsh requires zsh + git to install.
# - macOS: zsh ships with the OS since Catalina; git via Xcode CLT or brew.
#          Don't auto-install — tell the user how.
# - Linux: not always pre-installed. AUTO-INSTALL via apt/dnf/pacman if
#          sudo is available; fall back to graceful skip otherwise.
missing=()
command -v zsh >/dev/null 2>&1 || missing+=("zsh")
command -v git >/dev/null 2>&1 || missing+=("git")

if [[ ${#missing[@]} -gt 0 ]]; then
    echo "==> Missing dependencies for oh-my-zsh: ${missing[*]}"

    case "$(uname -s)" in
        Darwin)
            # macOS: no auto-install. User has Homebrew via the brew script
            # that runs before this one; they can install with `brew install`.
            echo "    Install with:   brew install ${missing[*]}"
            echo "    Then re-run:    chezmoi apply --force"
            exit 0
            ;;

        Linux)
            # Linux: try to auto-install with the detected package manager.
            # Bail gracefully if no PM or no sudo (locked-down systems).
            #
            # Per-PM commands as ARRAYS — we run each as a separate sudo'd
            # call so privilege is correctly applied to every step.
            # (Previously used `eval "$SUDO $INSTALL_CMD"` where INSTALL_CMD
            # contained `&&` — sudo only applied to the first command, so
            # `apt-get install` ran without root and failed with
            # 'Could not open lock file /var/lib/dpkg/lock-frontend'.)
            PM_NAME=""
            UPDATE_CMD=()
            INSTALL_CMD=()
            if   command -v apt-get >/dev/null 2>&1; then
                PM_NAME="apt-get"
                UPDATE_CMD=(apt-get update)
                INSTALL_CMD=(apt-get install -y "${missing[@]}")
            elif command -v dnf     >/dev/null 2>&1; then
                PM_NAME="dnf"
                UPDATE_CMD=(true)                            # dnf caches automatically
                INSTALL_CMD=(dnf install -y "${missing[@]}")
            elif command -v pacman  >/dev/null 2>&1; then
                PM_NAME="pacman"
                UPDATE_CMD=(pacman -Sy)
                INSTALL_CMD=(pacman -S --noconfirm "${missing[@]}")
            else
                echo "    No supported package manager (apt/dnf/pacman) detected."
                echo "    Install ${missing[*]} manually, then: chezmoi apply --force"
                exit 0
            fi

            # Decide on sudo: not needed if root; required otherwise.
            if [[ $EUID -eq 0 ]]; then
                SUDO=()
            elif command -v sudo >/dev/null 2>&1; then
                SUDO=(sudo)
                if ! sudo -n true 2>/dev/null; then
                    echo "    (sudo may prompt for your password)"
                fi
            else
                echo "    No sudo available. Install ${missing[*]} as root, then:"
                echo "      chezmoi apply --force"
                exit 0
            fi

            echo "    Auto-installing (PM=$PM_NAME): ${UPDATE_CMD[*]} && ${INSTALL_CMD[*]}"

            # Run each command separately so sudo applies to BOTH.
            # `${SUDO[@]+"${SUDO[@]}"}` is the empty-array guard for set -u.
            if ! "${SUDO[@]+"${SUDO[@]}"}" "${UPDATE_CMD[@]}"; then
                echo "==> Package index update FAILED. Inspect output above, then:"
                echo "      chezmoi apply --force"
                exit 0
            fi
            if ! "${SUDO[@]+"${SUDO[@]}"}" "${INSTALL_CMD[@]}"; then
                echo "==> Auto-install FAILED. Inspect output above, then:"
                echo "      chezmoi apply --force"
                exit 0
            fi
            ;;

        *)
            echo "    Unsupported OS: $(uname -s). Skip."
            exit 0
            ;;
    esac
fi

# zsh + git are present (either pre-installed or just auto-installed)
echo "==> Installing oh-my-zsh (unattended)"
sh -c "$(curl -fsSL https://raw.githubusercontent.com/ohmyzsh/ohmyzsh/master/tools/install.sh)" "" --unattended --keep-zshrc

echo "==> oh-my-zsh installed"
