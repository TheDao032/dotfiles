#!/usr/bin/env bash
# Idempotently install/update oh-my-zsh custom plugins from zsh-users.
#
# Re-runs whenever the embedded plugin-list hash below changes (chezmoi
# `run_onchange_` hashes the rendered file). Adding/removing a plugin in
# .chezmoidata.toml therefore re-triggers this script.
#
# Tracked plugin set: {{ .tools.omz_plugins | toJson }}
set -euo pipefail

ZSH_CUSTOM="${ZSH_CUSTOM:-$HOME/.oh-my-zsh/custom}"

if [ ! -d "$HOME/.oh-my-zsh" ]; then
    echo "oh-my-zsh not installed yet — skipping custom plugin install." >&2
    exit 0
fi

# Map plugin name -> git repo. Only zsh-users plugins are cloned here; any
# bundled OMZ plugins (git, kubectl, docker, ...) are part of oh-my-zsh itself.
declare -A REPOS=(
  [zsh-autosuggestions]="https://github.com/zsh-users/zsh-autosuggestions.git"
  [zsh-syntax-highlighting]="https://github.com/zsh-users/zsh-syntax-highlighting.git"
  [zsh-completions]="https://github.com/zsh-users/zsh-completions.git"
)

mkdir -p "$ZSH_CUSTOM/plugins"

for name in "${!REPOS[@]}"; do
    dest="$ZSH_CUSTOM/plugins/$name"
    if [ -d "$dest/.git" ]; then
        echo "→ updating $name"
        git -C "$dest" pull --ff-only --quiet
    else
        echo "→ cloning  $name"
        git clone --depth=1 --quiet "${REPOS[$name]}" "$dest"
    fi
done

# Silence "insecure directories" warnings on next compinit by tightening perms
# on the newly cloned trees. Mirrors what dot_zshrc.tmpl already does at runtime.
find "$ZSH_CUSTOM/plugins" -type d -perm -g+w -exec chmod g-w {} + 2>/dev/null || true

echo "oh-my-zsh custom plugins ready."
