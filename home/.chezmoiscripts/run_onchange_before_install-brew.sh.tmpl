{{- if eq .chezmoi.os "darwin" }}
#!/usr/bin/env bash
# run_onchange_before_install-brew.sh — install Homebrew if missing.
# Runs BEFORE chezmoi apply, so the brew shellenv is available for later scripts.
# Re-runs whenever this script's content changes.

set -euo pipefail

if ! command -v brew >/dev/null 2>&1; then
    echo "==> Installing Homebrew"
    /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
fi

# Pick up brew on first install (Apple Silicon path)
{{- if eq .chezmoi.arch "arm64" }}
[ -x "{{ .paths.homebrew_prefix_arm }}/bin/brew" ] && eval "$({{ .paths.homebrew_prefix_arm }}/bin/brew shellenv)"
{{- else }}
[ -x "{{ .paths.homebrew_prefix_intel }}/bin/brew" ] && eval "$({{ .paths.homebrew_prefix_intel }}/bin/brew shellenv)"
{{- end }}

echo "==> brew $(brew --version | head -1)"
{{- end }}
