# Brewfile — declarative install for macOS AND Linux (linuxbrew).
# Apply with: brew bundle (chezmoi runs this automatically on apply via
# .chezmoiscripts/run_onchange_after_install-brew-bundle.sh.tmpl).
#
# Sections gated `{{`{{ if eq .chezmoi.os "darwin" }}`}}` are macOS-only —
# linuxbrew has no GUI casks and no PAM/keychain integration.
#
# SCOPE (trimmed 2026-07-05): only the Neovim + terminal stack and a focused
# infrastructure toolset. Language version managers, cloud CLIs, containers,
# and all non-terminal GUI apps were intentionally removed.
#
# NOTE: `brew bundle` only INSTALLS. Removing a line here does NOT uninstall the
# package — run `brew bundle cleanup --file=~/.Brewfile` to remove anything no
# longer listed (see README "Trimming packages").

# ─── Custom taps ────────────────────────────────────────────────────────────
# NOTE (all Macs — Apple Silicon AND Intel): tapping hashicorp/tap triggers a
# cosmetic error during `brew bundle`'s import scan:
#   Error: Failed to load formula: vagrant
#   hashicorp/tap/vagrant: formula requires at least a URL
#   Warning: Treating vagrant as a cask.      ← Homebrew RECOVERS here
# Cause: hashicorp/tap's vagrant.rb only defines a URL for `OS.linux? && Hardware::CPU.intel?`.
# On macOS (either chip) the formula has no URL → Homebrew refuses to load it, then
# falls back to the cask. This is unavoidable while the tap is present because:
#   - we NEED this tap for packer + terraform (no longer in homebrew-core post-BUSL),
#   - vagrant on Mac is delivered by `cask "vagrant"` below — not by this formula.
# The "Warning: Treating vagrant as a cask" line means it RECOVERED — this error is
# NOT what fails `brew bundle`. It is loud but harmless on Intel too.
# Verified 2026-06-12 (Dao); re-confirmed on Intel MacBook Pro 2018, 2026-07-04.
tap "hashicorp/tap"

# ═══ KEEP: dotfiles system (REQUIRED — chezmoi + secrets + pre-commit hook) ═══
brew "age"                          # file encryption for chezmoi secrets
brew "chezmoi"                      # this dotfiles manager
brew "gitleaks"                     # secret scan — used by ~/.config/git/hooks/pre-commit

# ═══ KEEP: shell + terminal ══════════════════════════════════════════════════
brew "zsh-autosuggestions"          # auto-suggest history matches
brew "tmux"                         # terminal multiplexer
brew "bat"                          # better cat
brew "btop"                         # better top/htop
brew "fzf"                          # fuzzy finder
brew "watch"                        # repeat command + show output
brew "wget"                         # http downloader
brew "gh"                           # GitHub CLI
brew "lazygit"                      # tui git

# ═══ KEEP: Neovim ════════════════════════════════════════════════════════════
brew "neovim"                       # editor
brew "tree-sitter-cli"              # syntax parser (neovim treesitter)
brew "hunspell"                     # spell checker (neovim / editors)

# ═══ KEEP: infrastructure / devops ═══════════════════════════════════════════
brew "go"                           # Go language
brew "ansible"                      # config management
brew "hashicorp/tap/packer"         # image builder
brew "hashicorp/tap/terraform"      # IaC
brew "terragrunt"                   # terraform wrapper
brew "argocd"                       # GitOps for k8s
brew "helm"                         # k8s package manager
brew "kubernetes-cli"               # kubectl
brew "k9s"                          # k8s tui
brew "qemu"                         # vagrant provider (vagrant-qemu plugin uses this)

{{ if eq .chezmoi.os "darwin" -}}
# ═══ KEEP: macOS-only (PAM / casks) ══════════════════════════════════════════
brew "pam-reattach"                 # tmux + Touch ID
brew "reattach-to-user-namespace"   # tmux + macOS clipboard

cask "kitty@nightly"                # GPU-accelerated terminal
cask "vagrant"                      # VM orchestrator (provider: qemu, above)
{{- end }}

# ─── Vagrant plugins (NOT in Brewfile — managed via vagrant plugin install) ──
# - vagrant-qemu (installed by run_once_after_install-vagrant-qemu-plugin.sh)

# ─── REMOVED 2026-07-05 (kept out on purpose; re-add if needed) ──────────────
# lang managers/runtimes : jenv nvm rbenv rustup openjdk openjdk@17 python-tk@3.14
# cloud CLIs             : awscli azure-cli
# containers             : docker docker-buildx docker-compose colima
# AI/LLM                 : ollama
# dev tools              : mermaid-cli protobuf
# GUI casks              : cursor claude claude-code codex android-commandlinetools
#                          flutter google-chrome firefox slack microsoft-teams
#                          discord obsidian figma spotify virtualbox utm bitwarden
#                          cloudflare-warp ngrok parsec
# (pdk cask was deleted from Homebrew upstream — do NOT re-add; it aborts brew bundle.)
