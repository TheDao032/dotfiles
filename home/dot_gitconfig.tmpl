[user]
    name  = {{ .user.name }}
    email = {{ .user.email }}

# Multi-account: any repo whose working tree lives under ~/Documents/Bosch/
# gets the work identity from ~/.gitconfig-work instead of the [user] block above.
# Trailing `/` is required — without it, git does NOT recurse into subdirectories.
# Verify per-repo with:  git config user.email
[includeIf "gitdir:~/Documents/Bosch/"]
    path = ~/.gitconfig-work

[init]
    defaultBranch = main

[pull]
    rebase = false

[fetch]
    prune = true

# Rewrite https → ssh for orgs we contribute to.
[url "git@github.com:{{ .user.github }}/"]
    insteadOf = https://github.com/{{ .user.github }}/

[url "git@github.com:TMMFZ/"]
    insteadOf = https://github.com/TMMFZ/

[credential]
    helper = osxkeychain

{{- /* gh CLI credential helper for github.com — if installed, use it for HTTPS
       so `git push https://github.com/...` auto-uses the PAT stored by
       `gh auth login`. Without this block, gh-managed credentials are
       invisible to git. */}}
{{- if lookPath "gh" }}
[credential "https://github.com"]
    helper =
    helper = !{{ lookPath "gh" }} auth git-credential
[credential "https://gist.github.com"]
    helper =
    helper = !{{ lookPath "gh" }} auth git-credential
{{- end }}

[core]
    excludesfile = ~/.gitignore
    editor = {{ .tools.editor }}
    # Managed pre-commit hook runs `gitleaks protect --staged` to block
    # accidental secret commits. Bypass for a single commit: git commit --no-verify
    hooksPath = ~/.config/git/hooks

# Nicer diffs (delta if installed, else plain)
[diff]
    colorMoved = default
{{- if lookPath "delta" }}
[core]
    pager = delta
[interactive]
    diffFilter = delta --color-only
[delta]
    navigate = true
    light = false
[merge]
    conflictstyle = zdiff3
{{- end }}
